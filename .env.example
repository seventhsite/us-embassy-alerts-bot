# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# RSS polling interval in seconds (default: 1800 = 30 minutes)
POLL_INTERVAL_SECONDS=3600

# Path to SQLite database file
DB_PATH=/data/bot.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum free subscriptions per user (default: 3)
MAX_FREE_SUBSCRIPTIONS=3

# Cloudflare Worker RSS proxy (required)
# Deploy the worker from cloudflare-worker/ directory, then set the URL here.
# See README for deployment instructions.
RSS_PROXY_URL=https://usembassy-rss-proxy.YOUR_SUBDOMAIN.workers.dev
RSS_PROXY_KEY=your_secret_key_here
