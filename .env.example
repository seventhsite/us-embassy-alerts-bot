# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# RSS polling interval in seconds (default: 1800 = 30 minutes)
POLL_INTERVAL_SECONDS=1800

# Path to SQLite database file
DB_PATH=/data/bot.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum free subscriptions per user (default: 3)
MAX_FREE_SUBSCRIPTIONS=3

# Proxy URL for RSS requests (required for datacenter IPs blocked by CloudFront)
# US Embassy sites block datacenter/hosting IPs via CloudFront WAF.
# A residential or mobile proxy is needed when running on VPS/cloud servers.
# Supports: http, https, socks4, socks5
# Examples:
#   PROXY_URL=http://user:pass@proxy.example.com:8080
#   PROXY_URL=socks5://user:pass@proxy.example.com:1080
PROXY_URL=
